def normalize_text(text: str) -> str:
    if not text:
        return ""
    normalized = unicodedata.normalize("NFKD", text)
    normalized = "".join(
        character for character in normalized if not unicodedata.combining(character)
    )
    normalized = normalized.lower().replace("&", " and ")
    normalized = re.sub(r"[\r\n\t]+", " ", normalized)
    normalized = re.sub(r"[^a-z0-9]+", " ", normalized)
    normalized = re.sub(r"\s+", " ", normalized).strip()
    return normalized


def join_non_empty_unique(parts: list[str]) -> str:
    seen: set[str] = set()
    cleaned_parts: list[str] = []
    for part in parts:
        part = (part or "").strip()
        if not part:
            continue
        key = normalize_text(part)
        if not key or key in seen:
            continue
        cleaned_parts.append(part)
        seen.add(key)
    return "\n\n".join(cleaned_parts).strip()


def count_words(text: str) -> int:
    return len(re.findall(r"[A-Za-zÀ-ÿ0-9']+", text or ""))


def text_signature(text: str) -> str:
    normalized = normalize_text(text)
    return hashlib.sha1(normalized.encode("utf-8")).hexdigest()


def scored_result(
    scores: collections.Counter,
    min_score: float,
    default_label: str,
    multi_threshold_ratio: float = 0.6,
) -> dict[str, Any]:
    ordered = scores.most_common()
    top_3 = [
        {"label": label, "score": round(score, 2)}
        for label, score in ordered[:MAX_TOP_LABELS]
    ]

    if not ordered:
        return {
            "best_label": default_label,
            "best_score": 0.0,
            "top_3_labels": top_3,
            "selected_labels": [default_label] if default_label != "Autre" else [],
            "score_map": {},
        }

    best_label, best_score = ordered[0]
    selected_labels = [
        label
        for label, score in ordered
        if score >= min_score and score >= best_score * multi_threshold_ratio
    ]

    if best_score < min_score:
        best_label = default_label
        selected_labels = [default_label] if default_label not in {"Autre", "Inconnu"} else []

    return {
        "best_label": best_label,
        "best_score": round(best_score if ordered else 0.0, 2),
        "top_3_labels": top_3,
        "selected_labels": selected_labels,
        "score_map": {label: round(score, 2) for label, score in ordered},
    }


def score_pattern_dictionary(
    field_texts: dict[str, str],
    pattern_dictionary: dict[str, list[tuple[str, float]]],
    field_weights: dict[str, float],
) -> tuple[collections.Counter, dict[str, list[dict[str, Any]]]]:
    scores: collections.Counter = collections.Counter()
    matches: dict[str, list[dict[str, Any]]] = collections.defaultdict(list)

    normalized_fields = {
        field_name: normalize_text(text) for field_name, text in field_texts.items()
    }

    for label, weighted_patterns in pattern_dictionary.items():
        for field_name, normalized_text_value in normalized_fields.items():
            if not normalized_text_value:
                continue
            field_multiplier = field_weights.get(field_name, 0.0)
            if field_multiplier <= 0:
                continue
            for pattern, base_score in weighted_patterns:
                if re.search(pattern, normalized_text_value, re.IGNORECASE):
                    score_value = base_score * field_multiplier
                    scores[label] += score_value
                    matches[label].append(
                        {
                            "field": field_name,
                            "pattern": pattern,
                            "score": round(score_value, 2),
                        }
                    )
    return scores, matches


def score_simple_patterns(text: str, patterns: list[tuple[str, float]]) -> float:
    normalized = normalize_text(text)
    score = 0.0
    for pattern, weight in patterns:
        if re.search(pattern, normalized, re.IGNORECASE):
            score += weight
    return round(score, 2)


def tokenize_words(text: str, stopwords: set[str]) -> list[str]:
    tokens: list[str] = []
    for raw_word in re.findall(r"[A-Za-zÀ-ÿ0-9']+", text or ""):
        normalized = normalize_text(raw_word)
        if len(normalized) < MIN_TOKEN_LENGTH:
            continue
        if normalized in stopwords:
            continue
        tokens.append(normalized)
    return tokens


def top_word_counter(texts: list[str], stopwords: set[str]) -> collections.Counter:
    counter: collections.Counter = collections.Counter()
    for text in texts:
        for token in tokenize_words(text, stopwords):
            counter[token] += 1
    return counter


def counter_to_records(counter: collections.Counter, limit: int = TOP_WORDS_LIMIT) -> list[dict[str, Any]]:
    return [{"word": word, "count": count} for word, count in counter.most_common(limit)]


def count_pipe_values(series: pd.Series) -> collections.Counter:
    counter: collections.Counter = collections.Counter()
    for value in series.fillna(""):
        for item in [chunk.strip() for chunk in str(value).split(" | ") if chunk.strip()]:
            counter[item] += 1
    return counter


def percent(part: int, whole: int) -> float:
    if whole <= 0:
        return 0.0
    return round((part / whole) * 100, 1)


def top_labels_as_text(records: list[dict[str, Any]]) -> str:
    return " | ".join(
        f"{record['label']} ({record['score']})" for record in records if record.get("label")
    )


