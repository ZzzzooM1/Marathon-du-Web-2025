def detect_platforms(content: dict[str, Any], filename: str) -> dict[str, Any]:
    texts = extract_analysis_texts(content)
    field_texts = {
        "filename": Path(filename).stem,
        "ocr": texts["ocr_text"],
        "model": texts["model_description_text"],
        "combined": texts["combined_analysis_text"],
    }
    field_weights = {"filename": 2.4, "ocr": 1.6, "model": 1.2, "combined": 0.4}
    scores, matches = score_pattern_dictionary(field_texts, PLATFORM_PATTERNS, field_weights)
    result = scored_result(scores, MIN_SCORE_PLATFORM, "Inconnu", multi_threshold_ratio=0.45)

    selected = result["selected_labels"] or ["Inconnu"]
    if "Inconnu" in selected and len(selected) > 1:
        selected = [label for label in selected if label != "Inconnu"]

    return {
        "platforms": selected,
        "best_label": result["best_label"],
        "best_score": result["best_score"],
        "top_3_labels": result["top_3_labels"],
        "score_map": result["score_map"],
        "match_details": matches,
    }


def classify_topic(content: dict[str, Any], filename: str) -> dict[str, Any]:
    texts = extract_analysis_texts(content)
    field_texts = {
        "filename": Path(filename).stem,
        "ocr": texts["ocr_text"],
        "model": texts["model_description_text"],
        "combined": texts["combined_analysis_text"],
    }
    field_weights = {"filename": 1.2, "ocr": 1.4, "model": 1.2, "combined": 0.5}
    scores, matches = score_pattern_dictionary(field_texts, TOPIC_PATTERNS, field_weights)

    usage_hint = normalize_text(texts["model_description_text"])
    if re.search(r"\bselfie\b|\bportrait\b|\bfriends\b|\bfamily\b", usage_hint):
        scores["Vie quotidienne / Personnel"] += 1.5
    if re.search(r"\bdocument\b|\bposter\b|\bflyer\b|\bcertificate\b", usage_hint):
        scores["Documents / Affiches"] += 1.2
    if re.search(r"\bmeme\b|\bfunny\b|\bjoke\b|\bgif\b", usage_hint):
        scores["Meme / Divertissement"] += 1.2

    result = scored_result(scores, MIN_SCORE_TOPIC, "Autre", multi_threshold_ratio=0.65)
    return {
        "label": result["best_label"],
        "score": result["best_score"],
        "top_3_labels": result["top_3_labels"],
        "score_map": result["score_map"],
        "match_details": matches,
    }


def classify_image_usage(content: dict[str, Any], filename: str) -> dict[str, Any]:
    texts = extract_analysis_texts(content)
    field_texts = {
        "filename": Path(filename).stem,
        "ocr": texts["ocr_text"],
        "model": texts["model_description_text"],
        "combined": texts["combined_analysis_text"],
    }
    field_weights = {"filename": 1.1, "ocr": 1.0, "model": 1.8, "combined": 0.6}
    scores, matches = score_pattern_dictionary(field_texts, IMAGE_USAGE_PATTERNS, field_weights)

    normalized_model = normalize_text(texts["model_description_text"])
    normalized_combined = normalize_text(texts["combined_analysis_text"])
    ocr_word_count = count_words(texts["ocr_text"])
    is_text_heavy = (
        ocr_word_count >= TEXT_HEAVY_WORD_THRESHOLD
        or len(texts["ocr_text"]) >= TEXT_HEAVY_CHAR_THRESHOLD
    )

    if is_text_heavy:
        scores["document_affiche"] += 1.2
        if re.search(r"\bnews\b|\bheadline\b|\barticle\b|\bjournal\b", normalized_combined):
            scores["actualite_capture"] += 1.3

    if re.search(r"\bscreenshot\b", normalized_model):
        scores["capture_interface"] += 1.8
        if re.search(
            r"\bpost\b|\btweet\b|\bthread\b|\bstory\b|\breel\b|\bsocial media\b",
            normalized_combined,
        ):
            scores["reseau_social_post"] += 2.0
        if re.search(r"\bheadline\b|\bnews\b|\barticle\b|\bjournal\b", normalized_combined):
            scores["actualite_capture"] += 1.8

    if score_simple_patterns(texts["combined_analysis_text"], FAKE_NEWS_LIKE_PATTERNS) >= 2.0:
        scores["fake_news_probable"] += 2.0

    if re.search(r"\bselfie\b|\bportrait\b|\bmirror selfie\b", normalized_model):
        scores["selfie_portrait"] += 2.0

    if re.search(r"\bfriends\b|\bfamily\b|\bliving room\b|\bbedroom\b", normalized_model):
        scores["photo_personnelle"] += 1.5

    if re.search(r"\bbutton\b|\bmenu\b|\binterface\b|\bwebsite\b|\bapp\b", normalized_model):
        scores["capture_interface"] += 1.6

    if re.search(r"\bdocument\b|\bposter\b|\bflyer\b|\bcertificate\b", normalized_model):
        scores["document_affiche"] += 1.6

    if re.search(r"\bmeme\b|\bfunny\b|\bjoke\b|\bgif\b", normalized_combined):
        scores["image_meme_divertissement"] += 1.8

    result = scored_result(scores, MIN_SCORE_USAGE, "autre", multi_threshold_ratio=0.7)
    return {
        "label": result["best_label"],
        "score": result["best_score"],
        "top_3_labels": result["top_3_labels"],
        "score_map": result["score_map"],
        "match_details": matches,
        "is_text_heavy_hint": is_text_heavy,
    }


def detect_rhetorical_patterns(content: dict[str, Any]) -> dict[str, Any]:
    texts = extract_analysis_texts(content)
    field_texts = {
        "ocr": texts["ocr_text"],
        "model": texts["model_description_text"],
        "combined": texts["combined_analysis_text"],
    }
    field_weights = {"ocr": 1.4, "model": 1.0, "combined": 0.6}
    scores, matches = score_pattern_dictionary(field_texts, RHETORICAL_PATTERNS, field_weights)

    ordered = [
        {"label": label, "score": round(score, 2)}
        for label, score in scores.most_common()
        if score >= MIN_SCORE_RHETORIC
    ]
    return {
        "labels": [item["label"] for item in ordered],
        "top_3_labels": ordered[:MAX_TOP_LABELS],
        "score_map": {label: round(score, 2) for label, score in scores.most_common()},
        "match_details": matches,
    }


def derive_usage_flags(
    content: dict[str, Any],
    texts: dict[str, str],
    usage_result: dict[str, Any],
    topic_result: dict[str, Any],
    platform_result: dict[str, Any],
    rhetoric_result: dict[str, Any],
) -> dict[str, bool]:
    combined_text = texts["combined_analysis_text"]
    fake_score = score_simple_patterns(combined_text, FAKE_NEWS_LIKE_PATTERNS)
    personal_score = score_simple_patterns(combined_text, PERSONAL_IMAGE_PATTERNS)
    test_score = score_simple_patterns(
        f"{content.get('filename', '')} {combined_text}",
        TEST_IMAGE_PATTERNS,
    )
    news_score = score_simple_patterns(combined_text, NEWS_LIKE_PATTERNS)
    social_score = score_simple_patterns(combined_text, SOCIAL_MEDIA_LIKE_PATTERNS)

    ocr_word_count = count_words(texts["ocr_text"])
    description_word_count = count_words(texts["model_description_text"])
    total_word_count = count_words(texts["combined_analysis_text"])

    is_text_heavy = (
        usage_result.get("is_text_heavy_hint", False)
        or ocr_word_count >= TEXT_HEAVY_WORD_THRESHOLD
        or len(texts["ocr_text"]) >= TEXT_HEAVY_CHAR_THRESHOLD
    )

    is_personal_image = (
        usage_result["label"] in PERSONAL_USAGE_TYPES
        or personal_score >= 1.5
    )
    is_social_media_like = (
        usage_result["label"] == "reseau_social_post"
        or any(label in SOCIAL_PLATFORM_LABELS for label in platform_result["platforms"])
        or social_score >= 1.2
    )
    is_news_like = (
        usage_result["label"] in NEWS_USAGE_TYPES
        or topic_result["label"]
        in {
            "Politique / Societe",
            "Geopolitique / Conflits internationaux",
            "Securite / Immigration / Tensions sociales",
            "France / Municipales / Montpellier",
            "Sante / Science",
            "Guerre / Catastrophe",
            "Conspirations / Desinformation",
        }
        or news_score >= 1.2
        or fake_score >= 1.5
    )
    is_fake_news_like = (
        usage_result["label"] == "fake_news_probable"
        or fake_score >= 2.5
        or (is_news_like and len(rhetoric_result["labels"]) >= 2)
    )
    is_nearly_empty = total_word_count <= MIN_WORDS_NEAR_EMPTY
    is_test_image = (
        is_nearly_empty
        or (
            not is_fake_news_like
            and (
                is_personal_image
                or usage_result["label"] in GENERIC_TEST_USAGE_TYPES
                or test_score >= 1.5
            )
        )
    )

    if description_word_count > 0 and ocr_word_count == 0 and usage_result["label"] == "capture_interface":
        is_test_image = True

    return {
        "is_fake_news_like": bool(is_fake_news_like),
        "is_personal_image": bool(is_personal_image),
        "is_test_image": bool(is_test_image),
        "is_news_like": bool(is_news_like),
        "is_social_media_like": bool(is_social_media_like),
        "is_text_heavy": bool(is_text_heavy),
        "is_nearly_empty": bool(is_nearly_empty),
    }


