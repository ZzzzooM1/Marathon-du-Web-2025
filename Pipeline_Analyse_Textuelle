def export_reports(df: pd.DataFrame, aggregates: dict[str, Any], output_dir: Path) -> None:
    output_dir.mkdir(parents=True, exist_ok=True)

    report_json = {
        "generated_at": datetime.now().isoformat(timespec="seconds"),
        "input_dir": str(INPUT_DIR.resolve()),
        "output_dir": str(output_dir.resolve()),
        "config": {
            "MIN_SCORE_TOPIC": MIN_SCORE_TOPIC,
            "MIN_SCORE_USAGE": MIN_SCORE_USAGE,
            "MIN_SCORE_PLATFORM": MIN_SCORE_PLATFORM,
            "MIN_SCORE_RHETORIC": MIN_SCORE_RHETORIC,
            "TOP_WORDS_LIMIT": TOP_WORDS_LIMIT,
            "MIN_WORDS_NEAR_EMPTY": MIN_WORDS_NEAR_EMPTY,
            "TEXT_HEAVY_WORD_THRESHOLD": TEXT_HEAVY_WORD_THRESHOLD,
