    }

    (output_dir / "rapport.json").write_text(
        json.dumps(report_json, ensure_ascii=False, indent=2),
        encoding="utf-8",
    )
    df.to_csv(output_dir / "documents.csv", index=False, encoding="utf-8-sig")

    aggregate_rows: list[dict[str, Any]] = []
    for key, value in aggregates["summary"].items():
        aggregate_rows.append({"group": "summary", "label": key, "count": value})
