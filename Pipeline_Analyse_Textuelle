    )

    pd.DataFrame(aggregates["top_words_ocr"]).to_csv(
        output_dir / "top_words_ocr.csv",
        index=False,
        encoding="utf-8-sig",
    )
    pd.DataFrame(aggregates["top_words_descriptions"]).to_csv(
        output_dir / "top_words_descriptions.csv",
        index=False,
        encoding="utf-8-sig",
    )
    pd.DataFrame(aggregates["top_words_combined"]).to_csv(
        output_dir / "top_words_combined.csv",
        index=False,
        encoding="utf-8-sig",
    )

    (output_dir / "soutenance_summary.md").write_text(
        generate_soutenance_summary(df, aggregates),
        encoding="utf-8",
    )


