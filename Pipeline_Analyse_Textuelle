def process_file(filepath: Path) -> dict[str, Any]:
    content = parse_content(filepath)
    content["filename"] = filepath.name
    texts = extract_analysis_texts(content)
    platform_result = detect_platforms(content, filepath.name)
    topic_result = classify_topic(content, filepath.name) if ENABLED_ANALYSES["topics"] else {
        "label": "Autre",
        "score": 0.0,
        "top_3_labels": [],
        "score_map": {},
        "match_details": {},
    }
    usage_result = (
        classify_image_usage(content, filepath.name)
        if ENABLED_ANALYSES["image_usage"]
        else {
            "label": "autre",
            "score": 0.0,
            "top_3_labels": [],
            "score_map": {},
            "match_details": {},
            "is_text_heavy_hint": False,
        }
    )
    rhetoric_result = (
        detect_rhetorical_patterns(content)
        if ENABLED_ANALYSES["rhetoric"]
        else {"labels": [], "top_3_labels": [], "score_map": {}, "match_details": {}}
    )
    flags = derive_usage_flags(
        content,
        texts,
        usage_result,
        topic_result,
        platform_result,
        rhetoric_result,
    )

    ocr_word_count = count_words(texts["ocr_text"])
    description_word_count = count_words(texts["model_description_text"])
    total_word_count = count_words(texts["combined_analysis_text"])

    record = {
        "filename": filepath.name,
        "filepath": str(filepath.resolve()),
        "parse_status": "ok" if content["is_readable"] else "read_error",
        "parse_error": content.get("read_error", ""),
        "detected_sections": content.get("detected_sections", []),
        "section_titles": content.get("section_titles", {}),
        "ocr_text": texts["ocr_text"],
        "model_description_text": texts["model_description_text"],
        "combined_analysis_text": texts["combined_analysis_text"],
        "platforms": platform_result["platforms"],
        "primary_platform": platform_result["best_label"],
        "primary_platform_score": platform_result["best_score"],
        "platform_top_3": platform_result["top_3_labels"],
        "platform_score_map": platform_result["score_map"],
        "topic": topic_result["label"],
        "topic_score": topic_result["score"],
        "topic_top_3": topic_result["top_3_labels"],
        "topic_score_map": topic_result["score_map"],
        "image_usage_type": usage_result["label"],
        "image_usage_score": usage_result["score"],
        "image_usage_top_3": usage_result["top_3_labels"],
        "image_usage_score_map": usage_result["score_map"],
        "rhetorical_patterns": rhetoric_result["labels"],
        "rhetorical_top_3": rhetoric_result["top_3_labels"],
        "rhetorical_score_map": rhetoric_result["score_map"],
        "ocr_word_count": ocr_word_count,
        "description_word_count": description_word_count,
        "total_word_count": total_word_count,
        "has_ocr": bool(texts["ocr_text"].strip()),
        "has_model_description": bool(texts["model_description_text"].strip()),
        **flags,
    }
    return record


def mark_duplicates(records: list[dict[str, Any]]) -> None:
    seen_signatures: dict[str, str] = {}
    for record in records:
        signature_source = record["combined_analysis_text"] or record["ocr_text"] or record["model_description_text"]
        signature = text_signature(signature_source) if signature_source else text_signature(record["filename"])
        record["content_signature"] = signature
        if signature in seen_signatures:
            record["is_duplicate"] = True
            record["duplicate_of"] = seen_signatures[signature]
        else:
            record["is_duplicate"] = False
            record["duplicate_of"] = ""
            seen_signatures[signature] = record["filename"]


