def save_chart(fig: plt.Figure, output_dir: Path, filename: str) -> None:
    path = output_dir / filename
    fig.savefig(path, dpi=150, bbox_inches="tight")
    plt.close(fig)
    LOGGER.info("Graphique enregistre : %s", path.name)


def plot_counter_barh(
    counter: collections.Counter,
    title: str,
    xlabel: str,
    output_dir: Path,
    filename: str,
    limit: int = 10,
    exclude: set[str] | None = None,
) -> None:
    exclude = exclude or set()
    items = [(label, count) for label, count in counter.most_common(limit) if label not in exclude]
    if not items:
        return
    labels, values = zip(*items)
    fig, ax = plt.subplots(figsize=(10, 5))
    bars = ax.barh(labels[::-1], values[::-1], color=COLORS[: len(labels)])
    ax.set_title(title, fontsize=14, fontweight="bold")
    ax.set_xlabel(xlabel)
    for bar, value in zip(bars, values[::-1]):
        ax.text(bar.get_width() + 0.2, bar.get_y() + bar.get_height() / 2, str(value), va="center")
    for side in ("top", "right"):
        ax.spines[side].set_visible(False)
    plt.tight_layout()
    save_chart(fig, output_dir, filename)


def plot_summary_charts(
    df: pd.DataFrame,
    output_dir: Path,
    aggregates: dict[str, Any] | None = None,
) -> None:
    output_dir.mkdir(parents=True, exist_ok=True)
    if aggregates is None:
        aggregates = build_aggregates(df)

    usage_counter = collections.Counter(aggregates["usage_counts"])
    topic_counter = collections.Counter(aggregates["topic_counts"])
    platform_counter = collections.Counter(aggregates["platform_counts"])
    rhetoric_counter = collections.Counter(aggregates["rhetorical_counts"])

    plot_counter_barh(
        usage_counter,
        "Types d'usage reel des images",
        "Nombre de documents",
        output_dir,
        "01_usage_types.png",
        limit=10,
    )
    plot_counter_barh(
        platform_counter,
        "Plateformes detectees",
        "Nombre de documents",
        output_dir,
        "02_platforms.png",
        limit=12,
        exclude={"Inconnu"},
    )
    plot_counter_barh(
        topic_counter,
        "Thematiques detectees",
        "Nombre de documents",
        output_dir,
        "03_topics.png",
        limit=10,
        exclude={"Autre"},
    )
    plot_counter_barh(
        rhetoric_counter,
        "Patterns rhetoriques",
        "Nombre de documents",
        output_dir,
        "04_rhetorical_patterns.png",
        limit=10,
    )

    if not df.empty:
        fake_like = int(df["is_fake_news_like"].sum())
        personal = int(df["is_personal_image"].sum())
        social = int(df["is_social_media_like"].sum())
        test = int(df["is_test_image"].sum())
        other = max(len(df) - len(df[df["is_test_image"] | df["is_personal_image"] | df["is_fake_news_like"]]), 0)

        values = [value for value in [fake_like, personal, social, test, other] if value > 0]
        labels = [
            label
            for label, value in zip(
                [
                    f"Fake-news like ({fake_like})",
                    f"Images personnelles ({personal})",
                    f"Reseaux sociaux ({social})",
                    f"Usages de test ({test})",
                    f"Autres ({other})",
                ],
                [fake_like, personal, social, test, other],
            )
            if value > 0
        ]
        if values:
            fig, ax = plt.subplots(figsize=(8, 8))
            ax.pie(
                values,
                labels=labels,
                autopct="%1.1f%%",
                startangle=90,
                colors=COLORS[: len(values)],
                wedgeprops={"edgecolor": "white", "linewidth": 2},
            )
            ax.set_title("Repartition des usages observes", fontsize=14, fontweight="bold")
            save_chart(fig, output_dir, "05_usage_split.png")

        fig, ax = plt.subplots(figsize=(10, 5))
        flag_names = [
            "is_fake_news_like",
            "is_personal_image",
            "is_test_image",
            "is_news_like",
            "is_social_media_like",
            "is_text_heavy",
        ]
        flag_counts = [int(df[flag].sum()) for flag in flag_names]
        pretty_labels = [
            "Fake news like",
            "Personnel",
            "Test",
            "News like",
            "Social media",
            "Texte dense",
        ]
        ax.bar(pretty_labels, flag_counts, color=COLORS[: len(pretty_labels)])
        ax.set_title("Flags de cadrage", fontsize=14, fontweight="bold")
        ax.set_ylabel("Nombre de documents")
        plt.xticks(rotation=25, ha="right")
        for side in ("top", "right"):
            ax.spines[side].set_visible(False)
        plt.tight_layout()
        save_chart(fig, output_dir, "06_flags_overview.png")

        fig, axes = plt.subplots(1, 3, figsize=(18, 5))
        top_word_groups = [
            ("OCR", aggregates["top_words_ocr"]),
            ("Descriptions modele", aggregates["top_words_descriptions"]),
            ("Combine", aggregates["top_words_combined"]),
        ]
        for axis, (title, records) in zip(axes, top_word_groups):
            subset = records[:10]
            if not subset:
                axis.axis("off")
                continue
            words = [item["word"] for item in subset][::-1]
            counts = [item["count"] for item in subset][::-1]
            axis.barh(words, counts, color=COLORS[0])
            axis.set_title(title)
        plt.tight_layout()
        save_chart(fig, output_dir, "07_top_words_comparison.png")

        usage_topic = pd.crosstab(df["image_usage_type"], df["topic"])
        if not usage_topic.empty:
            fig, ax = plt.subplots(figsize=(12, 6))
            image = ax.imshow(usage_topic.values, cmap="YlOrRd", aspect="auto")
            ax.set_xticks(range(len(usage_topic.columns)))
            ax.set_yticks(range(len(usage_topic.index)))
            ax.set_xticklabels(usage_topic.columns, rotation=35, ha="right", fontsize=9)
            ax.set_yticklabels(usage_topic.index, fontsize=9)
            plt.colorbar(image, ax=ax, label="Nombre de documents")
            ax.set_title("Croisement usage reel x thematique", fontsize=14, fontweight="bold")
            plt.tight_layout()
            save_chart(fig, output_dir, "08_usage_topic_heatmap.png")

        if HAS_WORDCLOUD and ENABLE_WORDCLOUDS and ENABLED_ANALYSES["wordclouds"]:
            wordcloud_specs = [
                ("09_wordcloud_ocr.png", aggregates["top_words_ocr"], "Wordcloud OCR", "white", "viridis"),
                (
                    "10_wordcloud_descriptions.png",
                    aggregates["top_words_descriptions"],
                    "Wordcloud descriptions modele",
                    "white",
                    "plasma",
                ),
                (
                    "11_wordcloud_combined.png",
                    aggregates["top_words_combined"],
                    "Wordcloud combine",
                    "#0F172A",
                    "magma",
                ),
            ]
            for filename, records, title, background, colormap in wordcloud_specs:
                frequencies = {item["word"]: item["count"] for item in records[:150]}
                if not frequencies:
                    continue
                wc = WordCloud(
                    width=1200,
                    height=600,
                    background_color=background,
                    colormap=colormap,
                    max_words=120,
                ).generate_from_frequencies(frequencies)
                fig, ax = plt.subplots(figsize=(14, 7))
                ax.imshow(wc, interpolation="bilinear")
                ax.axis("off")
                ax.set_title(title, fontsize=14, fontweight="bold")
                save_chart(fig, output_dir, filename)


