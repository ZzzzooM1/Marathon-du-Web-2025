def build_aggregates(df: pd.DataFrame) -> dict[str, Any]:
    total_documents = int(len(df))
    platform_counts = count_pipe_values(df["platforms"]) if "platforms" in df else collections.Counter()
    rhetoric_counts = (
        count_pipe_values(df["rhetorical_patterns"])
        if "rhetorical_patterns" in df
        else collections.Counter()
    )
    topic_counts = collections.Counter(df["topic"].fillna("").tolist())
    usage_counts = collections.Counter(df["image_usage_type"].fillna("").tolist())

    ocr_counter = top_word_counter(df["ocr_text"].fillna("").tolist(), STOPWORDS_FR_EN)
    description_counter = top_word_counter(
        df["model_description_text"].fillna("").tolist(),
        STOPWORDS_FR_EN,
    )
    combined_counter = top_word_counter(
        df["combined_analysis_text"].fillna("").tolist(),
        STOPWORDS_FR_EN,
    )

    summary = {
        "total_documents": total_documents,
        "documents_with_ocr": int(df["has_ocr"].sum()) if not df.empty else 0,
        "documents_with_model_description": int(df["has_model_description"].sum()) if not df.empty else 0,
        "fake_news_like_documents": int(df["is_fake_news_like"].sum()) if not df.empty else 0,
        "personal_image_documents": int(df["is_personal_image"].sum()) if not df.empty else 0,
        "test_image_documents": int(df["is_test_image"].sum()) if not df.empty else 0,
        "news_like_documents": int(df["is_news_like"].sum()) if not df.empty else 0,
        "social_media_like_documents": int(df["is_social_media_like"].sum()) if not df.empty else 0,
        "text_heavy_documents": int(df["is_text_heavy"].sum()) if not df.empty else 0,
        "near_empty_documents": int(df["is_nearly_empty"].sum()) if not df.empty else 0,
        "duplicate_documents": int(df["is_duplicate"].sum()) if not df.empty else 0,
        "read_error_documents": int((df["parse_status"] != "ok").sum()) if not df.empty else 0,
        "average_ocr_words": round(float(df["ocr_word_count"].mean()), 2) if not df.empty else 0.0,
        "average_description_words": round(float(df["description_word_count"].mean()), 2)
        if not df.empty
        else 0.0,
        "average_total_words": round(float(df["total_word_count"].mean()), 2) if not df.empty else 0.0,
    }

    return {
        "summary": summary,
        "platform_counts": dict(platform_counts.most_common()),
        "topic_counts": dict(topic_counts.most_common()),
        "usage_counts": dict(usage_counts.most_common()),
        "rhetorical_counts": dict(rhetoric_counts.most_common()),
        "top_words_ocr": counter_to_records(ocr_counter),
        "top_words_descriptions": counter_to_records(description_counter),
        "top_words_combined": counter_to_records(combined_counter),
    }


