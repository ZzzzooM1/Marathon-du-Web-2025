def collect_records(input_dir: Path) -> list[dict[str, Any]]:
    records: list[dict[str, Any]] = []
    seen_file_names: set[str] = set()

    if not input_dir.exists():
        raise FileNotFoundError(f"Dossier introuvable : {input_dir}")

    for filepath in sorted(input_dir.glob("*.txt")):
        if filepath.name in seen_file_names:
            LOGGER.warning("Nom de fichier duplique ignore : %s", filepath.name)
            continue
        seen_file_names.add(filepath.name)
        try:
            record = process_file(filepath)
        except Exception:
            LOGGER.exception("Erreur non bloquante pendant le traitement de %s", filepath)
            record = {
                "filename": filepath.name,
                "filepath": str(filepath.resolve()),
                "parse_status": "processing_error",
                "parse_error": "processing_error",
                "detected_sections": [],
                "section_titles": {},
                "ocr_text": "",
                "model_description_text": "",
                "combined_analysis_text": "",
                "platforms": ["Inconnu"],
                "primary_platform": "Inconnu",
                "primary_platform_score": 0.0,
                "platform_top_3": [],
                "platform_score_map": {},
                "topic": "Autre",
                "topic_score": 0.0,
                "topic_top_3": [],
                "topic_score_map": {},
                "image_usage_type": "autre",
                "image_usage_score": 0.0,
                "image_usage_top_3": [],
                "image_usage_score_map": {},
                "rhetorical_patterns": [],
                "rhetorical_top_3": [],
                "rhetorical_score_map": {},
                "ocr_word_count": 0,
                "description_word_count": 0,
                "total_word_count": 0,
                "has_ocr": False,
                "has_model_description": False,
                "is_fake_news_like": False,
                "is_personal_image": False,
                "is_test_image": True,
                "is_news_like": False,
                "is_social_media_like": False,
                "is_text_heavy": False,
                "is_nearly_empty": True,
            }
        records.append(record)

    mark_duplicates(records)
    return records


def main() -> None:
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    setup_logging(OUTPUT_DIR)

    LOGGER.info("Debut de l'analyse")
    LOGGER.info("Input dir : %s", INPUT_DIR)
    LOGGER.info("Output dir : %s", OUTPUT_DIR)

    records = collect_records(INPUT_DIR)
    df = build_daily_dataframe(records)
    aggregates = build_aggregates(df)

    export_reports(df, aggregates, OUTPUT_DIR)
    plot_summary_charts(df, OUTPUT_DIR, aggregates)

    summary = aggregates["summary"]
    LOGGER.info("Documents analyses : %s", summary["total_documents"])
    LOGGER.info(
        "Fake news like : %s (%s %%)",
        summary["fake_news_like_documents"],
        percent(summary["fake_news_like_documents"], summary["total_documents"]),
    )
    LOGGER.info(
        "Images personnelles : %s (%s %%)",
        summary["personal_image_documents"],
        percent(summary["personal_image_documents"], summary["total_documents"]),
    )
    LOGGER.info(
        "Usages de test : %s (%s %%)",
        summary["test_image_documents"],
        percent(summary["test_image_documents"], summary["total_documents"]),
    )
    LOGGER.info("Analyse terminee")


if __name__ == "__main__":
    main()
