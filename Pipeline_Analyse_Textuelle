def match_section_title(raw_title: str) -> str | None:
    normalized_title = normalize_text(raw_title)
    if not normalized_title:
        return None
    for canonical_name, patterns in SECTION_TITLE_PATTERNS:
        for pattern in patterns:
            if re.search(pattern, normalized_title, re.IGNORECASE):
                return canonical_name
    return None


def detect_source_sections(text: str) -> dict[str, Any]:
    normalized_newlines = (text or "").replace("\r\n", "\n").replace("\r", "\n")
    lines = normalized_newlines.split("\n")
    headers: list[dict[str, Any]] = []

    for line_index, line in enumerate(lines):
        match = HEADER_LINE_RE.match(line.strip())
        if not match:
            continue
        raw_title = match.group(1).strip()
        if not raw_title:
            continue
        headers.append(
            {
                "line_index": line_index,
                "raw_title": raw_title,
                "canonical_title": match_section_title(raw_title),
            }
        )

    sections = {
        "ocr": "",
        "description": "",
        "description_detailed": "",
        "photos": "",
    }
    other_sections: dict[str, str] = {}
    section_titles: dict[str, list[str]] = collections.defaultdict(list)

    if not headers:
        return {
            "sections": sections,
            "other_sections": other_sections,
            "section_titles": section_titles,
            "detected_sections": [],
        }

    for index, header in enumerate(headers):
        start = header["line_index"] + 1
        end = headers[index + 1]["line_index"] if index + 1 < len(headers) else len(lines)
        body = "\n".join(lines[start:end]).strip()
        raw_title = header["raw_title"]
        canonical_title = header["canonical_title"]

        if canonical_title == "description_detailed":
            key = "description_detailed"
        elif canonical_title == "description":
            key = "description"
        elif canonical_title == "ocr":
            key = "ocr"
        elif canonical_title == "photos":
            key = "photos"
        else:
            key = None

        if key is None:
            if body:
                other_sections[raw_title] = body
            continue

        sections[key] = join_non_empty_unique([sections[key], body])
        section_titles[key].append(raw_title)

    detected_sections = [key for key, value in sections.items() if value]
    return {
        "sections": sections,
        "other_sections": other_sections,
        "section_titles": dict(section_titles),
        "detected_sections": detected_sections,
    }


def looks_like_model_description(text: str) -> bool:
    normalized = normalize_text(text)
    indicative_patterns = [
        r"\bthe image\b",
        r"\bthe screenshot\b",
        r"\bthe photo\b",
        r"\bthere is\b",
        r"\bthere are\b",
        r"\bon the screen\b",
        r"\bin the image\b",
        r"\ba person\b",
    ]
    return any(re.search(pattern, normalized) for pattern in indicative_patterns)


def parse_content(filepath: Path) -> dict[str, Any]:
    content = {
        "filepath": str(filepath.resolve()),
        "filename": filepath.name,
        "raw_text": "",
        "ocr": "",
        "description": "",
        "description_detailed": "",
        "other_sections": {},
        "section_titles": {},
        "detected_sections": [],
        "read_error": "",
        "is_readable": True,
        "is_empty_file": False,
    }

    try:
        raw_text = filepath.read_text(encoding="utf-8", errors="ignore")
    except Exception as exc:
        LOGGER.exception("Lecture impossible pour %s", filepath)
        content["read_error"] = str(exc)
        content["is_readable"] = False
        return content

    content["raw_text"] = raw_text
    content["is_empty_file"] = not raw_text.strip()
    detected = detect_source_sections(raw_text)

    content["ocr"] = detected["sections"].get("ocr", "")
    content["description"] = detected["sections"].get("description", "")
    content["description_detailed"] = detected["sections"].get("description_detailed", "")
    content["other_sections"] = detected["other_sections"]
    content["section_titles"] = detected["section_titles"]
    content["detected_sections"] = detected["detected_sections"]

    if not any(
        [
            content["ocr"].strip(),
            content["description"].strip(),
            content["description_detailed"].strip(),
        ]
    ):
        fallback_text = raw_text.strip()
        if fallback_text:
            if looks_like_model_description(fallback_text):
                content["description_detailed"] = fallback_text
                content["detected_sections"] = ["description_detailed"]
                content["section_titles"] = {"description_detailed": ["fallback_full_text"]}
            else:
                content["ocr"] = fallback_text
                content["detected_sections"] = ["ocr"]
                content["section_titles"] = {"ocr": ["fallback_full_text"]}

    return content


def extract_analysis_texts(content: dict[str, Any]) -> dict[str, str]:
    ocr_text = (content.get("ocr") or "").strip()
    model_description_text = join_non_empty_unique(
        [
            (content.get("description") or "").strip(),
            (content.get("description_detailed") or "").strip(),
        ]
    )
    combined_analysis_text = join_non_empty_unique([ocr_text, model_description_text])
    return {
        "ocr_text": ocr_text,
        "model_description_text": model_description_text,
        "combined_analysis_text": combined_analysis_text,
    }


